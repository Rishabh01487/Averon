# ══════════════════════════════════════════════════════════════════════════════
# AVERON — Configuration Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4200
NODE_ENV=development
CLUSTER=true                          # Enable cluster mode (auto in production)
CLUSTER_WORKERS=                      # Number of workers (default: CPU count)

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=                           # Auto-generated if empty (will invalidate on restart)
JWT_REFRESH_SECRET=                   # Auto-generated if empty
CORS_ORIGINS=http://localhost:4200    # Comma-separated allowed origins

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                       # Google Gemini API key for AI asset analysis

# ── Payment Gateways ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=                      # Razorpay live/test key ID
RAZORPAY_KEY_SECRET=                  # Razorpay key secret
RAZORPAY_WEBHOOK_SECRET=              # Razorpay webhook signature secret

STRIPE_SECRET_KEY=                    # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_WEBHOOK_SECRET=                # Stripe webhook signing secret

WIRE_BANK_NAME=Averon Settlement Account  # Display name for wire transfers
WIRE_ACCOUNT_NUMBER=****1234             # Wire transfer account number (last 4 only)
WIRE_IFSC=AVRN0001234                    # Wire IFSC code

UPI_ID=averon@upi                       # UPI ID for UPI payments

# ── Database ──────────────────────────────────────────────────────────────────
# Uses SQLite (file-based). No external DB needed.
# Data stored in ./data/averon.db

# ── Admin (optional — set on first registration) ──────────────────────────────
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
